#!/bin/bash

# githubssh - Convert a GitHub repo's remote from HTTPS to SSH, and verify setup

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# ── 1. Check SSH key exists ────────────────────────────────────────────────────
KEY=""
for k in ~/.ssh/id_ed25519 ~/.ssh/id_rsa ~/.ssh/id_ecdsa; do
  if [[ -f "$k" ]]; then
    KEY="$k"
    break
  fi
done

if [[ -z "$KEY" ]]; then
  echo -e "${RED}✗ No SSH key found in ~/.ssh${NC}"
  echo "  Generate one with: ssh-keygen -t ed25519 -C \"your@email.com\""
  exit 1
fi
echo -e "${GREEN}✓ SSH key found:${NC} $KEY.pub"

# ── 2. Ensure key is added to ssh-agent ───────────────────────────────────────
if ! ssh-add -l &>/dev/null; then
  eval "$(ssh-agent -s)" &>/dev/null
fi

if ! ssh-add -l 2>/dev/null | grep -q "$KEY"; then
  ssh-add "$KEY" 2>/dev/null
fi

# ── 3. Test GitHub authentication ─────────────────────────────────────────────
AUTH=$(ssh -o ConnectTimeout=5 -T git@github.com 2>&1)
if echo "$AUTH" | grep -q "successfully authenticated"; then
  GITHUB_USER=$(echo "$AUTH" | grep -o 'Hi [^!]*' | cut -d' ' -f2)
  echo -e "${GREEN}✓ Authenticated with GitHub${NC} as $GITHUB_USER"
else
  echo -e "${RED}✗ SSH authentication with GitHub failed${NC}"
  echo "  Make sure your public key is added at: https://github.com/settings/ssh/new"
  echo "  Your public key:"
  cat "$KEY.pub"
  exit 1
fi

# ── 4. Fix remote URL if in a git repo ────────────────────────────────────────
if ! git rev-parse --git-dir &>/dev/null; then
  echo -e "${YELLOW}⚠ Not inside a git repository — skipping remote update${NC}"
  exit 0
fi

CURRENT_URL=$(git remote get-url origin 2>/dev/null)

if [[ -z "$CURRENT_URL" ]]; then
  echo -e "${YELLOW}⚠ No remote named 'origin' found${NC}"
  exit 0
fi

if echo "$CURRENT_URL" | grep -q "^git@github.com"; then
  echo -e "${GREEN}✓ Remote is already using SSH:${NC} $CURRENT_URL"
  exit 0
fi

if echo "$CURRENT_URL" | grep -q "^https://github.com"; then
  # Convert https://github.com/USER/REPO.git → git@github.com:USER/REPO.git
  SSH_URL=$(echo "$CURRENT_URL" | sed 's|https://github.com/|git@github.com:|')
  git remote set-url origin "$SSH_URL"
  echo -e "${GREEN}✓ Remote updated to SSH:${NC} $SSH_URL"
else
  echo -e "${YELLOW}⚠ Remote URL doesn't look like a standard GitHub URL:${NC} $CURRENT_URL"
fi
